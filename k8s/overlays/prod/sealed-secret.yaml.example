# Sealed Secret for norppalive-discord bot
#
# To create the actual sealed secret:
#
# 1. Create a plain Kubernetes secret:
#    kubectl create secret generic discord-bot-secrets \
#      --namespace=norppalive \
#      --from-literal=DISCORD_TOKEN='<discord-bot-token>' \
#      --dry-run=client -o yaml | kubeseal --format yaml > sealed-secret.yaml
#
# 2. Commit the generated sealed-secret.yaml (safe to store in git)
#
# Required keys:
#   DISCORD_TOKEN - Discord bot token
