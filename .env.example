# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your-discord-bot-token-here

# Kafka broker address
KAFKA_BROKER=localhost:19092

# Kafka topic for seal detection events
KAFKA_TOPIC=detection

# Kafka topic for settings updates from the dashboard (default: guild-settings-update)
KAFKA_SETTINGS_TOPIC=guild-settings-update

# Kafka topics for bot-dashboard interactivity
KAFKA_GUILD_EVENTS_TOPIC=bot-guild-events
KAFKA_ERROR_EVENTS_TOPIC=bot-error-events
KAFKA_BOT_REQUEST_TOPIC=bot-request
KAFKA_BOT_REPLY_TOPIC=bot-reply

# Shared API key for authenticating with the backend
BOT_API_KEY=change-me-to-a-secret

# Backend gRPC address (plain gRPC, not gRPC-Web; bypasses Envoy)
BACKEND_GRPC_URL=http://localhost:50051

# Log level
RUST_LOG=norppalive_discord=info
