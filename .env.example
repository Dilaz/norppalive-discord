# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your-discord-bot-token-here

# Kafka broker address
KAFKA_BROKER=localhost:19092

# Kafka topic for seal detection events
KAFKA_TOPIC=detection

# Kafka topic for settings updates from the dashboard (default: guild-settings-update)
KAFKA_SETTINGS_TOPIC=guild-settings-update

# Backend gRPC address (plain gRPC, not gRPC-Web; bypasses Envoy)
BACKEND_GRPC_URL=http://localhost:50051

# Log level
RUST_LOG=norppalive_discord=info
